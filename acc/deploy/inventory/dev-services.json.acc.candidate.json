{
  "profile": "dev",
  "services": [
    {
      "module": "ACC",
      "hostAlias": "acc-dev",
      "sshHostEnvKey": "ACC_SSH_HOST",
      "sshUserEnvKey": "ACC_SSH_USER",
      "deployBase": "/opt/cpf/acc",
      "healthUrl": "http://localhost:8082/actuator/health",
      "serviceName": "cpf-acc",
      "portEnvKey": "ACC_SERVER_PORT",
      "profile": "dev",
      "runtimeMode": "embedded-bootjar",
      "approvalRequired": true,
      "rollbackEnabled": true
    }
  ]
}