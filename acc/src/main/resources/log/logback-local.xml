<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <property name="MODULE_NAME" value="acc" />
    <property name="LOG_PATH" value="${CPF_LOGGING_FILE_BASE_PATH:-logs}" />
    <property name="LOG_PATTERN" value="[%d{yyyy-MM-dd HH:mm:ss.SSS}] [%thread] %-5level %logger{36} [TranId: %X{transactionId}] [BizTranId: %X{businessTransactionId}] [TraceId: %X{traceId}] [SpanId: %X{spanId}] [DynLevel: %X{dynamicLogLevel}] - %msg%n" />

    <!-- CPF 설정 설명입니다. -->
    <statusListener class="ch.qos.logback.core.status.OnConsoleStatusListener"/>

    <!-- CPF 설정 설명입니다. -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <charset>UTF-8</charset>
            <pattern>${LOG_PATTERN}</pattern>
        </encoder>
    </appender>

    <!-- CPF 설정 설명입니다. -->
    <appender name="MODULE_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <!-- CPF 설정 설명입니다. -->
            <fileNamePattern>${LOG_PATH}/${MODULE_NAME}/${MODULE_NAME}-%d{yyyy-MM-dd}.log</fileNamePattern>
            <maxHistory>30</maxHistory>
            <totalSizeCap>1GB</totalSizeCap>
        </rollingPolicy>
        <encoder>
            <charset>UTF-8</charset>
            <pattern>${LOG_PATTERN}</pattern>
        </encoder>
    </appender>

    <!-- CPF 설정 설명입니다. -->
    <appender name="CMN_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <!-- CPF 설정 설명입니다. -->
            <fileNamePattern>${LOG_PATH}/${MODULE_NAME}/cmn-%d{yyyy-MM-dd}.log</fileNamePattern>
            <maxHistory>30</maxHistory>
            <totalSizeCap>1GB</totalSizeCap>
        </rollingPolicy>
        <encoder>
            <charset>UTF-8</charset>
            <pattern>${LOG_PATTERN}</pattern>
        </encoder>
    </appender>

    <!-- CPF 설정 설명입니다. -->
    <appender name="PFW_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>${LOG_PATH}/${MODULE_NAME}/pfw-%d{yyyy-MM-dd}.log</fileNamePattern>
            <maxHistory>30</maxHistory>
            <totalSizeCap>1GB</totalSizeCap>
        </rollingPolicy>
        <encoder>
            <charset>UTF-8</charset>
            <pattern>${LOG_PATTERN}</pattern>
        </encoder>
    </appender>

    <!-- CPF 설정 설명입니다. -->
    <appender name="TRANSACTION_FILE" class="ch.qos.logback.classic.sift.SiftingAppender">
        <discriminator class="ch.qos.logback.classic.sift.MDCBasedDiscriminator">
            <key>transactionId</key>
            <defaultValue>NO_TRANSACTION</defaultValue>
        </discriminator>
        <timeout>30 minutes</timeout>
        <maxAppenderCount>1000</maxAppenderCount>
        <sift>
            <appender name="TRANSACTION-${transactionId}" class="ch.qos.logback.core.rolling.RollingFileAppender">
                <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
                    <fileNamePattern>${LOG_PATH}/${MODULE_NAME}/transactions/%d{yyyy-MM-dd}/${transactionId}.%i.log</fileNamePattern>
                    <maxFileSize>10MB</maxFileSize>
                    <maxHistory>30</maxHistory>
                    <totalSizeCap>2GB</totalSizeCap>
                </rollingPolicy>
                <encoder>
                    <charset>UTF-8</charset>
                    <pattern>${LOG_PATTERN}</pattern>
                </encoder>
            </appender>
        </sift>
    </appender>

    <!-- CPF 설정 설명입니다. -->
    <logger name="cpf.${MODULE_NAME}" level="DEBUG" additivity="false">
        <appender-ref ref="CONSOLE" />
        <appender-ref ref="MODULE_FILE" />
        <appender-ref ref="TRANSACTION_FILE" />
    </logger>

    <logger name="cpf.cmn" level="DEBUG" additivity="false">
        <appender-ref ref="CMN_FILE" />
        <appender-ref ref="TRANSACTION_FILE" />
    </logger>

    <logger name="cpf.pfw" level="DEBUG" additivity="false">
        <appender-ref ref="PFW_FILE" />
        <appender-ref ref="TRANSACTION_FILE" />
    </logger>

    <!-- CPF 설정 설명입니다. -->
    <logger name="org.apache.ibatis" level="DEBUG" additivity="true"/>
    <logger name="org.apache.ibatis.SQL" level="DEBUG" additivity="true"/>
    <logger name="org.apache.ibatis.mapping" level="DEBUG" additivity="true"/>
    <logger name="org.apache.ibatis.result" level="DEBUG" additivity="true"/>


    <!-- CPF 설정 설명입니다. -->
    <root level="DEBUG">
        <appender-ref ref="CONSOLE" />
        <appender-ref ref="MODULE_FILE" />
        <appender-ref ref="TRANSACTION_FILE" />
    </root>
</configuration>
