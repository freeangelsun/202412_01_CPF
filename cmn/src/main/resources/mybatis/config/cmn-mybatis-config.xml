<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE configuration PUBLIC "-//mybatis.org//DTD Config 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-config.dtd">

<configuration>
    <settings>
        <!-- mapUnderscoreToCamelCase: 스네이크 케이스(created_at)를 카멜 케이스(createdAt)로 자동 변환합니다. -->
        <setting name="mapUnderscoreToCamelCase" value="true"/>
        <!-- 쿼리 로그를 표준 출력으로 설정합니다. -->
        <setting name="logImpl" value="STDOUT_LOGGING"/>
    </settings>

    <typeAliases>
        <!-- CMN 샘플 도메인 엔티티에 대한 별칭을 자동으로 생성합니다. -->
        <package name="fps.cmn.smp.entity"/>
    </typeAliases>
</configuration>
