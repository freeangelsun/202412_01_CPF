<?xml version="1.0" encoding="UTF-8"?>
<configuration scan="false">
    <!-- EnvironmentPostProcessor가 계산한 절대 root와 실행 식별값을 모든 appender가 공유합니다. -->
    <springProperty scope="context" name="LOG_ROOT" source="cpf.logging.file.base-path" />
    <springProperty scope="context" name="CPF_ENV" source="cpf.environment" defaultValue="local" />
    <springProperty scope="context" name="MODULE_CODE" source="cpf.framework.module-id" defaultValue="app" />
    <springProperty scope="context" name="MODULE_PATH" source="cpf.logging.runtime-module-path" defaultValue="app" />
    <springProperty scope="context" name="INSTANCE_ID" source="cpf.framework.instance-id" defaultValue="local-01" />
    <springProperty scope="context" name="LOG_TIMEZONE" source="cpf.logging.file.timezone" defaultValue="Asia/Seoul" />
    <springProperty scope="context" name="MAX_HISTORY" source="cpf.logging.file.max-history-days" defaultValue="30" />
    <springProperty scope="context" name="TOTAL_SIZE_CAP" source="cpf.logging.file.total-size-cap" defaultValue="2GB" />

    <property name="INSTANCE_DIR" value="${LOG_ROOT}/${CPF_ENV}/${MODULE_PATH}/${INSTANCE_ID}" />
    <property name="LOG_PATTERN"
              value="%d{yyyy-MM-dd'T'HH:mm:ss.SSSXXX,${LOG_TIMEZONE}} level=%-5level environment=${CPF_ENV} runtimeModule=${MODULE_CODE} instance=${INSTANCE_ID} thread=%thread transactionId=%X{businessTransactionId} transactionGlobalId=%X{transactionId} traceId=%X{traceId} segmentId=%X{spanId} logger=%logger{40} message=%replace(%msg){'[\r\n]+','\\n'} exception=%replace(%ex){'[\r\n]+','\\n'}%n" />

    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <charset>UTF-8</charset>
            <pattern>${LOG_PATTERN}</pattern>
        </encoder>
    </appender>

    <!-- active 파일도 날짜를 포함하며 일자 변경 시 자동으로 새 파일을 엽니다. -->
    <appender name="APPLICATION_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>${INSTANCE_DIR}/application/cpf-${MODULE_CODE}-application-${INSTANCE_ID}.%d{yyyy-MM-dd,${LOG_TIMEZONE}}.log.gz</fileNamePattern>
            <maxHistory>${MAX_HISTORY}</maxHistory>
            <totalSizeCap>${TOTAL_SIZE_CAP}</totalSizeCap>
            <cleanHistoryOnStart>true</cleanHistoryOnStart>
        </rollingPolicy>
        <encoder>
            <charset>UTF-8</charset>
            <pattern>${LOG_PATTERN}</pattern>
        </encoder>
    </appender>

    <appender name="ERROR_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <filter class="ch.qos.logback.classic.filter.ThresholdFilter">
            <level>ERROR</level>
        </filter>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>${INSTANCE_DIR}/error/cpf-${MODULE_CODE}-error-${INSTANCE_ID}.%d{yyyy-MM-dd,${LOG_TIMEZONE}}.log.gz</fileNamePattern>
            <maxHistory>${MAX_HISTORY}</maxHistory>
            <totalSizeCap>${TOTAL_SIZE_CAP}</totalSizeCap>
            <cleanHistoryOnStart>true</cleanHistoryOnStart>
        </rollingPolicy>
        <encoder>
            <charset>UTF-8</charset>
            <pattern>${LOG_PATTERN}</pattern>
        </encoder>
    </appender>

    <appender name="PFW_FRAMEWORK_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>${INSTANCE_DIR}/framework/pfw/cpf-pfw-framework-${INSTANCE_ID}.%d{yyyy-MM-dd,${LOG_TIMEZONE}}.log.gz</fileNamePattern>
            <maxHistory>${MAX_HISTORY}</maxHistory>
            <totalSizeCap>${TOTAL_SIZE_CAP}</totalSizeCap>
            <cleanHistoryOnStart>true</cleanHistoryOnStart>
        </rollingPolicy>
        <encoder>
            <charset>UTF-8</charset>
            <pattern>${LOG_PATTERN}</pattern>
        </encoder>
    </appender>

    <appender name="CMN_COMMON_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>${INSTANCE_DIR}/common/cmn/cpf-cmn-common-${INSTANCE_ID}.%d{yyyy-MM-dd,${LOG_TIMEZONE}}.log.gz</fileNamePattern>
            <maxHistory>${MAX_HISTORY}</maxHistory>
            <totalSizeCap>${TOTAL_SIZE_CAP}</totalSizeCap>
            <cleanHistoryOnStart>true</cleanHistoryOnStart>
        </rollingPolicy>
        <encoder>
            <charset>UTF-8</charset>
            <pattern>${LOG_PATTERN}</pattern>
        </encoder>
    </appender>

    <logger name="cpf.pfw" level="INFO" additivity="true">
        <appender-ref ref="PFW_FRAMEWORK_FILE" />
    </logger>
    <logger name="cpf.cmn" level="INFO" additivity="true">
        <appender-ref ref="CMN_COMMON_FILE" />
    </logger>

    <!-- 거래별 동적 appender를 사용하지 않아 거래 ID가 없는 별도 파일이 생성되지 않습니다. -->
    <root level="INFO">
        <appender-ref ref="CONSOLE" />
        <appender-ref ref="APPLICATION_FILE" />
        <appender-ref ref="ERROR_FILE" />
    </root>
</configuration>
