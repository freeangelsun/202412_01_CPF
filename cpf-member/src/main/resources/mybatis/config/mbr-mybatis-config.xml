<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE configuration PUBLIC "-//mybatis.org//DTD Config 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-config.dtd">

<!--
  MBR 모듈 MyBatis 설정입니다.

  설정 기준
  - typeAliases: Mapper XML에서 사용할 도메인 별칭을 등록합니다.
  - mappers: 각 Mapper XML은 애플리케이션 설정의 mapper-locations에서 로딩합니다.
-->

<configuration>
    <!-- 회원 도메인 객체를 Mapper XML에서 Member 별칭으로 사용할 수 있게 등록합니다. -->
    <typeAliases>
        <typeAlias alias="Member" type="com.cpf.member.bse.entity.Member" />
    </typeAliases>
</configuration>
