DECLARE
    v_count NUMBER;
BEGIN
    SELECT COUNT(*) INTO v_count FROM user_tables WHERE table_name=UPPER('@CPF_TABLE_PREFIX@_sample_item');
    IF v_count=0 THEN
        EXECUTE IMMEDIATE q'[
          CREATE TABLE @CPF_TABLE_PREFIX@_sample_item (
            sample_item_id NUMBER(19) GENERATED BY DEFAULT AS IDENTITY PRIMARY KEY,
            sample_key VARCHAR2(100 CHAR) NOT NULL UNIQUE,
            item_name VARCHAR2(200 CHAR) NOT NULL,
            status_code VARCHAR2(30 CHAR) DEFAULT 'ACTIVE' NOT NULL,
            version_no NUMBER(19) DEFAULT 0 NOT NULL,
            idempotency_key VARCHAR2(100 CHAR) NOT NULL UNIQUE,
            transaction_global_id VARCHAR2(64 CHAR) NOT NULL,
            transaction_sequence NUMBER(19) DEFAULT 1 NOT NULL,
            transaction_at TIMESTAMP(3) DEFAULT SYSTIMESTAMP NOT NULL,
            deleted_yn CHAR(1 CHAR) DEFAULT 'N' NOT NULL,
            created_by VARCHAR2(100 CHAR) DEFAULT '@CPF_SYSTEM_CODE@' NOT NULL,
            created_at TIMESTAMP(3) DEFAULT SYSTIMESTAMP NOT NULL,
            updated_by VARCHAR2(100 CHAR) DEFAULT '@CPF_SYSTEM_CODE@' NOT NULL,
            updated_at TIMESTAMP(3) DEFAULT SYSTIMESTAMP NOT NULL,
            CONSTRAINT ck_@CPF_TABLE_PREFIX@_sample_item_ver CHECK(version_no>=0),
            CONSTRAINT ck_@CPF_TABLE_PREFIX@_sample_item_del CHECK(deleted_yn IN('Y','N'))
          )]';
        EXECUTE IMMEDIATE 'CREATE INDEX ix_@CPF_TABLE_PREFIX@_sample_item_st ON @CPF_TABLE_PREFIX@_sample_item(status_code,deleted_yn,sample_item_id)';
    END IF;
END;
/
