CREATE TABLE IF NOT EXISTS @CPF_TABLE_PREFIX@_sample_item (
    sample_item_id BIGINT GENERATED BY DEFAULT AS IDENTITY PRIMARY KEY,
    sample_key VARCHAR(100) NOT NULL UNIQUE,
    item_name VARCHAR(200) NOT NULL,
    status_code VARCHAR(30) NOT NULL DEFAULT 'ACTIVE',
    version_no BIGINT NOT NULL DEFAULT 0 CHECK (version_no >= 0),
    idempotency_key VARCHAR(100) NOT NULL UNIQUE,
    transaction_global_id VARCHAR(64) NOT NULL,
    transaction_sequence BIGINT NOT NULL DEFAULT 1,
    transaction_at TIMESTAMP(3) NOT NULL DEFAULT CURRENT_TIMESTAMP,
    deleted_yn CHAR(1) NOT NULL DEFAULT 'N' CHECK (deleted_yn IN ('Y', 'N')),
    created_by VARCHAR(100) NOT NULL DEFAULT '@CPF_SYSTEM_CODE@',
    created_at TIMESTAMP(3) NOT NULL DEFAULT CURRENT_TIMESTAMP,
    updated_by VARCHAR(100) NOT NULL DEFAULT '@CPF_SYSTEM_CODE@',
    updated_at TIMESTAMP(3) NOT NULL DEFAULT CURRENT_TIMESTAMP
);
CREATE INDEX IF NOT EXISTS ix_@CPF_TABLE_PREFIX@_sample_item_status
    ON @CPF_TABLE_PREFIX@_sample_item (status_code, deleted_yn, sample_item_id);
