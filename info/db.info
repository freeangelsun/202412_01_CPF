CREATE TABLE cache_refresh_event (
    event_id BIGINT PRIMARY KEY AUTO_INCREMENT,   -- 캐시 이벤트 ID
    cache_name VARCHAR(50) NOT NULL,              -- 대상 캐시명
    event_type VARCHAR(30) NOT NULL,              -- CREATE, UPDATE, DELETE, MANUAL_REFRESH
    event_key VARCHAR(200) NULL,                  -- 변경된 업무 키
    source_was_id VARCHAR(50) NULL,               -- 이벤트 발생 WAS
    published_by VARCHAR(100) NOT NULL DEFAULT 'SYSTEM', -- 이벤트 발행자
    published_at DATETIME(3) NOT NULL DEFAULT CURRENT_TIMESTAMP(3), -- 이벤트 발행 시각
    created_by VARCHAR(100) NOT NULL DEFAULT 'SYSTEM',
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    updated_by VARCHAR(100) NOT NULL DEFAULT 'SYSTEM',
    updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,
    INDEX IDX_CACHE_REFRESH_EVENT_CACHE_ID (cache_name, event_id),
    INDEX IDX_CACHE_REFRESH_EVENT_TIME (published_at)
);

