CREATE TABLE config_table (
    config_id INT PRIMARY KEY AUTO_INCREMENT,     -- 고유 ID
    config_key VARCHAR(100) NOT NULL,             -- 설정 키
    config_value VARCHAR(1000) NOT NULL,          -- 설정 값
    config_type VARCHAR(30) NOT NULL DEFAULT 'STRING', -- 설정 값 유형
    description VARCHAR(255) NULL,                -- 설정 설명
    encrypted_yn CHAR(1) NOT NULL DEFAULT 'N',    -- 암호화 대상 여부
    use_yn CHAR(1) NOT NULL DEFAULT 'Y',          -- 사용 여부
    created_by VARCHAR(100) NOT NULL DEFAULT 'SYSTEM',
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    updated_by VARCHAR(100) NOT NULL DEFAULT 'SYSTEM',
    updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,
    UNIQUE KEY UK_CONFIG_KEY (config_key),
    INDEX IDX_CONFIG_USE (use_yn)
);

