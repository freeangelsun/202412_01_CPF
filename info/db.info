CREATE DATABASE pfwDB;
USE pfwDB;

-- 프레임워크 필수 거래 로그 테이블
CREATE TABLE TRAN_LOG (
    LOG_DATE DATE NOT NULL, -- 로그 기준일자
    LOG_IDX BIGINT AUTO_INCREMENT PRIMARY KEY, -- 로그 인덱스
    TRANSACTION_ID VARCHAR(100) NOT NULL, -- 업무 거래 전체 추적 ID
    TRACE_ID VARCHAR(100) NOT NULL, -- 기술 추적 ID
    SPAN_ID VARCHAR(100), -- 현재 처리 구간 ID
    PARENT_SPAN_ID VARCHAR(100), -- 이전 처리 구간 ID
    SEQUENCE_NO INT NOT NULL DEFAULT 1, -- 동일 요청 내 로그 순번
    MODULE_ID VARCHAR(20) NOT NULL, -- 모듈 ID (ACC, MBR, CMN)
    MENU_ID VARCHAR(50), -- 거래(메뉴) ID
    BUSINESS_TRANSACTION_ID VARCHAR(12) NOT NULL, -- 컨트롤러 업무 거래ID
    BUSINESS_TRANSACTION_NAME VARCHAR(100) NOT NULL, -- 컨트롤러 업무 거래명
    LOG_TYPE VARCHAR(20) NOT NULL, -- SUCCESS, FAILURE
    REQUEST_TYPE VARCHAR(20) NOT NULL, -- 요청 구분
    ORIGINAL_CHANNEL_CODE VARCHAR(20) NOT NULL, -- 최초 전송 채널 코드
    CHANNEL_CODE VARCHAR(20) NOT NULL, -- 현재 전송 채널 코드
    MEMBER_NO VARCHAR(50), -- 회원 번호
    CUSTOMER_NO VARCHAR(50), -- 고객 번호
    SCREEN_ID VARCHAR(50), -- 화면 ID
    DEVICE_ID VARCHAR(100), -- 디바이스 ID
    CLIENT_REQUEST_TIME VARCHAR(30), -- 클라이언트 요청 일시
    WAS_ID VARCHAR(50) NOT NULL, -- 프레임워크 노드/WAS 인스턴스 번호
    RESERVED_FIELD_1 VARCHAR(255), -- 확장 예약 필드 1
    RESERVED_FIELD_2 VARCHAR(255), -- 확장 예약 필드 2
    RESERVED_FIELD_3 VARCHAR(255), -- 확장 예약 필드 3
    RESERVED_FIELD_4 VARCHAR(255), -- 확장 예약 필드 4
    RESERVED_FIELD_5 VARCHAR(255), -- 확장 예약 필드 5
    HTTP_METHOD VARCHAR(10), -- HTTP Method
    URI VARCHAR(500) NOT NULL, -- 요청 URI
    CONTROLLER VARCHAR(255), -- 컨트롤러 메서드
    EXECUTION_PACKAGE VARCHAR(255), -- 실제 실행 패키지명
    EXECUTION_CLASS VARCHAR(255), -- 실제 실행 클래스명
    EXECUTION_METHOD VARCHAR(100), -- 실제 실행 메서드명
    EXECUTION_SIGNATURE VARCHAR(1000), -- 실제 실행 메서드 시그니처
    WORKFLOW_ID VARCHAR(50), -- 워크플로우 ID
    WORKFLOW_NAME VARCHAR(100), -- 워크플로우명
    WORKFLOW_INSTANCE_ID VARCHAR(100), -- 워크플로우 인스턴스 ID
    WORKFLOW_STEP_ID VARCHAR(50), -- 워크플로우 스텝 ID
    WORKFLOW_STEP_NAME VARCHAR(100), -- 워크플로우 스텝명
    WORKFLOW_STATUS VARCHAR(30), -- 워크플로우 처리 상태
    WORKFLOW_FAILURE_POLICY VARCHAR(30), -- 실패 처리 정책
    COMPENSATION_YN CHAR(1) NOT NULL DEFAULT 'N', -- 보상 거래 여부
    COMPENSATION_TRANSACTION_ID VARCHAR(12), -- 보상 거래ID
    COMPENSATION_TARGET_TRANSACTION_ID VARCHAR(12), -- 보상 대상 원거래ID
    COMPENSATION_STATUS VARCHAR(30), -- 보상 처리 상태
    PARAMETERS MEDIUMTEXT, -- 요청 파라미터
    REQUEST_BODY MEDIUMTEXT, -- 요청 Body
    RESPONSE MEDIUMTEXT, -- 리턴값
    RESPONSE_CODE INT, -- 응답 코드
    ERROR_CODE VARCHAR(100), -- 표준 오류 코드
    EXTERNAL_MESSAGE VARCHAR(500), -- 고객용 오류 메시지
    INTERNAL_MESSAGE MEDIUMTEXT, -- 내부 추적용 오류 메시지
    ERROR_MESSAGE MEDIUMTEXT, -- 오류 정보
    EXEC_USER VARCHAR(100) NOT NULL DEFAULT 'N/A', -- 거래 수행 유저
    CLIENT_IP VARCHAR(100), -- 클라이언트 IP
    USER_AGENT VARCHAR(500), -- User-Agent
    START_TIME DATETIME(3) NOT NULL, -- 최초 수행 일시
    END_TIME DATETIME(3), -- 거래 종료 일시
    DURATION_MS BIGINT, -- 수행 시간
    CREATED_BY VARCHAR(100) NOT NULL DEFAULT 'SYSTEM', -- 등록자
    CREATED_AT DATETIME DEFAULT CURRENT_TIMESTAMP, -- 생성 시각
    UPDATED_BY VARCHAR(100) NOT NULL DEFAULT 'SYSTEM', -- 수정자
    UPDATED_AT DATETIME DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP, -- 수정 시각
    INDEX IDX_TRAN_LOG_DATE (LOG_DATE),
    INDEX IDX_TRAN_LOG_TRANSACTION_ID (TRANSACTION_ID),
    INDEX IDX_TRAN_LOG_TRANSACTION_TIME (TRANSACTION_ID, START_TIME, LOG_IDX),
    INDEX IDX_TRAN_LOG_TRACE_ID (TRACE_ID),
    INDEX IDX_TRAN_LOG_BUSINESS_TRANSACTION_ID (BUSINESS_TRANSACTION_ID),
    INDEX IDX_TRAN_LOG_BUSINESS_TIME (BUSINESS_TRANSACTION_ID, START_TIME),
    INDEX IDX_TRAN_LOG_MEMBER_NO (MEMBER_NO),
    INDEX IDX_TRAN_LOG_MEMBER_TIME (MEMBER_NO, START_TIME),
    INDEX IDX_TRAN_LOG_CUSTOMER_NO (CUSTOMER_NO),
    INDEX IDX_TRAN_LOG_CUSTOMER_TIME (CUSTOMER_NO, START_TIME),
    INDEX IDX_TRAN_LOG_CHANNEL_TIME (CHANNEL_CODE, START_TIME),
    INDEX IDX_TRAN_LOG_MODULE_TIME (MODULE_ID, START_TIME),
    INDEX IDX_TRAN_LOG_STATUS_TIME (LOG_TYPE, RESPONSE_CODE, START_TIME),
    INDEX IDX_TRAN_LOG_ERROR_CODE (ERROR_CODE, START_TIME),
    INDEX IDX_TRAN_LOG_WORKFLOW_INSTANCE (WORKFLOW_INSTANCE_ID),
    INDEX IDX_TRAN_LOG_WORKFLOW_TIME (WORKFLOW_INSTANCE_ID, START_TIME, LOG_IDX),
    INDEX IDX_TRAN_LOG_WORKFLOW_STEP (WORKFLOW_STEP_ID),
    INDEX IDX_TRAN_LOG_COMPENSATION (COMPENSATION_YN, COMPENSATION_STATUS),
    INDEX IDX_TRAN_LOG_EXECUTION_CLASS (EXECUTION_CLASS),
    INDEX IDX_TRAN_LOG_EXECUTION_TIME (EXECUTION_CLASS, EXECUTION_METHOD, START_TIME)
) ENGINE=InnoDB;

CREATE TABLE TRAN_LOG_DTL (
    DETAIL_ID BIGINT AUTO_INCREMENT PRIMARY KEY, -- 상세 로그 ID
    LOG_IDX BIGINT NOT NULL, -- 참조 로그 인덱스
    DETAIL_KEY VARCHAR(100) NOT NULL, -- 상세 키
    DETAIL_VALUE MEDIUMTEXT NOT NULL, -- 상세 값
    CREATED_BY VARCHAR(100) NOT NULL DEFAULT 'SYSTEM', -- 등록자
    CREATED_AT DATETIME DEFAULT CURRENT_TIMESTAMP, -- 생성 시각
    UPDATED_BY VARCHAR(100) NOT NULL DEFAULT 'SYSTEM', -- 수정자
    UPDATED_AT DATETIME DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP, -- 수정 시각
    FOREIGN KEY (LOG_IDX) REFERENCES TRAN_LOG(LOG_IDX) ON DELETE CASCADE,
    INDEX IDX_TRAN_LOG_DTL_LOG_IDX (LOG_IDX),
    INDEX IDX_TRAN_LOG_DTL_LOG_KEY (LOG_IDX, DETAIL_KEY)
) ENGINE=InnoDB;

commit;

