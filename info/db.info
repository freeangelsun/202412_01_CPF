CREATE TABLE message_table (
    message_id INT PRIMARY KEY AUTO_INCREMENT,    -- 고유 ID
    message_key VARCHAR(50) NOT NULL,             -- 메시지 키
    message_value VARCHAR(255) NOT NULL,          -- 메시지 내용
    locale VARCHAR(10) NOT NULL,                  -- 언어 설정 (예: en, ko)
    message_type VARCHAR(20) NOT NULL DEFAULT 'EXTERNAL', -- 메시지 유형(EXTERNAL/INTERNAL)
    description VARCHAR(255) NULL,                -- 메시지 설명
    use_yn CHAR(1) NOT NULL DEFAULT 'Y',          -- 사용 여부
    created_by VARCHAR(100) NOT NULL DEFAULT 'SYSTEM',
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    updated_by VARCHAR(100) NOT NULL DEFAULT 'SYSTEM',
    updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,
    UNIQUE KEY UK_MESSAGE_KEY_LOCALE_TYPE (message_key, locale, message_type),
    INDEX IDX_MESSAGE_TYPE (message_type, use_yn),
    INDEX IDX_MESSAGE_USE (use_yn)
);

