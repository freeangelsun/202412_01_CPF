<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<!--
  ?뚯썝(Member) MyBatis Mapper XML
  
  留ㅽ븨 ?뺣낫:
  - namespace: cpf.mbr.bse.mapper.MemberMapper
  - 二쇱슂 荑쇰━: selectAllMembers, selectMemberById, selectMembersByName, insertMember, updateMember, deleteMemberById
  
  紐낅챸 洹쒖튃:
  - select*: 議고쉶
  - insert*: ?깅줉
  - update*: ?섏젙
  - delete*: ??젣
  
  @author FPS Team
  @version 1.0.0
-->

<mapper namespace="cpf.mbr.bse.mapper.MemberMapper">
    
    <!-- ?꾩껜 ?뚯썝 議고쉶 -->
    <select id="selectAllMembers" resultMap="memberMap">
        SELECT id, name, description, created_by, created_at, updated_by, updated_at
        FROM member
        ORDER BY id DESC
    </select>
    
    <!-- ?뚯썝 ID濡??④굔 議고쉶 -->
    <select id="selectMemberById" parameterType="int" resultMap="memberMap">
        SELECT id, name, description, created_by, created_at, updated_by, updated_at
        FROM member
        WHERE id = #{id}
    </select>
    
    <!-- ?뚯썝紐낆쑝濡?遺遺?寃??-->
    <select id="selectMembersByName" parameterType="string" resultMap="memberMap">
        SELECT id, name, description, created_by, created_at, updated_by, updated_at
        FROM member
        WHERE name LIKE CONCAT('%', #{name}, '%')
        ORDER BY id DESC
    </select>
    
    <!-- ?뚯썝 ?깅줉 -->
    <insert id="insertMember" parameterType="Member" useGeneratedKeys="true" keyProperty="id" keyColumn="id">
        INSERT INTO member (name, description, created_by, created_at, updated_by, updated_at)
        VALUES (#{name}, #{description}, #{createdBy}, NOW(), #{updatedBy}, NOW())
    </insert>
    
    <!-- ?뚯썝 ?뺣낫 ?섏젙 -->
    <update id="updateMember" parameterType="Member">
        UPDATE member
        SET name = #{name},
            description = #{description},
            updated_by = #{updatedBy},
            updated_at = NOW()
        WHERE id = #{id}
    </update>
    
    <!-- ?뚯썝 ??젣 -->
    <delete id="deleteMemberById" parameterType="int">
        DELETE FROM member
        WHERE id = #{id}
    </delete>
    
    <!-- 寃곌낵 留ㅽ븨 ?뺤쓽 -->
    <resultMap id="memberMap" type="Member">
        <id column="id" property="id" />
        <result column="name" property="name" />
        <result column="description" property="description" />
        <result column="created_by" property="createdBy" />
        <result column="created_at" property="createdAt" />
        <result column="updated_by" property="updatedBy" />
        <result column="updated_at" property="updatedAt" />
    </resultMap>
</mapper>

