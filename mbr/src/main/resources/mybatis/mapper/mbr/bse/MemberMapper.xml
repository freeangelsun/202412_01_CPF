<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<!-- MBR 회원 샘플 Mapper입니다. -->
<mapper namespace="cpf.mbr.bse.mapper.MemberMapper">

    <sql id="memberColumns">
        id,
        member_no,
        customer_no,
        login_id,
        name,
        email,
        mobile_no,
        member_status,
        lock_yn,
        withdraw_yn,
        channel_code,
        joined_at,
        last_login_at,
        description,
        created_by,
        created_at,
        updated_by,
        updated_at
    </sql>

    <select id="selectAllMembers" resultMap="memberMap">
        SELECT <include refid="memberColumns" />
        FROM mbr_member
        ORDER BY id DESC
    </select>

    <select id="selectMemberById" parameterType="int" resultMap="memberMap">
        SELECT <include refid="memberColumns" />
        FROM mbr_member
        WHERE id = #{id}
    </select>

    <select id="selectMembersByName" parameterType="string" resultMap="memberMap">
        SELECT <include refid="memberColumns" />
        FROM mbr_member
        WHERE name LIKE CONCAT('%', #{name}, '%')
        ORDER BY id DESC
    </select>

    <insert id="insertMember" parameterType="Member" useGeneratedKeys="true" keyProperty="id" keyColumn="id">
        INSERT INTO mbr_member (
            member_no,
            customer_no,
            login_id,
            name,
            email,
            mobile_no,
            member_status,
            lock_yn,
            withdraw_yn,
            channel_code,
            joined_at,
            last_login_at,
            description,
            created_by,
            created_at,
            updated_by,
            updated_at
        )
        VALUES (
            #{memberNo},
            #{customerNo},
            #{loginId},
            #{name},
            #{email},
            #{mobileNo},
            #{memberStatus},
            #{lockYn},
            #{withdrawYn},
            #{channelCode},
            COALESCE(#{joinedAt}, NOW()),
            #{lastLoginAt},
            #{description},
            #{createdBy},
            NOW(),
            #{updatedBy},
            NOW()
        )
    </insert>

    <update id="updateMember" parameterType="Member">
        UPDATE mbr_member
        SET member_no = #{memberNo},
            customer_no = #{customerNo},
            login_id = #{loginId},
            name = #{name},
            email = #{email},
            mobile_no = #{mobileNo},
            member_status = #{memberStatus},
            lock_yn = #{lockYn},
            withdraw_yn = #{withdrawYn},
            channel_code = #{channelCode},
            last_login_at = #{lastLoginAt},
            description = #{description},
            updated_by = #{updatedBy},
            updated_at = NOW()
        WHERE id = #{id}
    </update>

    <delete id="deleteMemberById" parameterType="int">
        DELETE FROM mbr_member
        WHERE id = #{id}
    </delete>

    <resultMap id="memberMap" type="Member">
        <id column="id" property="id" />
        <result column="member_no" property="memberNo" />
        <result column="customer_no" property="customerNo" />
        <result column="login_id" property="loginId" />
        <result column="name" property="name" />
        <result column="email" property="email" />
        <result column="mobile_no" property="mobileNo" />
        <result column="member_status" property="memberStatus" />
        <result column="lock_yn" property="lockYn" />
        <result column="withdraw_yn" property="withdrawYn" />
        <result column="channel_code" property="channelCode" />
        <result column="joined_at" property="joinedAt" />
        <result column="last_login_at" property="lastLoginAt" />
        <result column="description" property="description" />
        <result column="created_by" property="createdBy" />
        <result column="created_at" property="createdAt" />
        <result column="updated_by" property="updatedBy" />
        <result column="updated_at" property="updatedAt" />
    </resultMap>
</mapper>
